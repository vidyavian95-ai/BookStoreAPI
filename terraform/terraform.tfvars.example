# Copy this file to terraform.tfvars and update with your values
# DO NOT commit terraform.tfvars to git

aws_region          = "ap-south-1"
project_name        = "bookstoreapi"
environment         = "production"
cluster_name        = "bookstoreapi-cluster"
kubernetes_version  = "1.30"
ecr_repository_name = "bookstoreapi"

# Network Configuration
vpc_cidr           = "10.0.0.0/16"
availability_zones = ["ap-south-1a", "ap-south-1b"]
private_subnets    = ["10.0.1.0/24", "10.0.2.0/24"]
public_subnets     = ["10.0.101.0/24", "10.0.102.0/24"]

# EKS Node Configuration
node_instance_type = "t3.small"  # Minimum recommended for EKS
node_min_size      = 2
node_max_size      = 3
node_desired_size  = 2

tags = {
  Project     = "BookStoreAPI"
  ManagedBy   = "Terraform"
  Environment = "production"
  Owner       = "YourName"
}
